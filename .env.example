# Required
OPENROUTER_API_KEY=sk-or-...
AGENTMAIL_API_KEY=...
AGENTMAIL_INBOX_ID=...
EMAIL_FROM=news-scout@example.com

# Optional
FEEDBACK_EMAIL=news-scout@example.com
FEEDBACK_SUBJECT=DPNS Feedback
FEEDBACK_URL=
LOG_LEVEL=INFO
LOG_FILE=data/logs/dpns.jsonl
DRY_RUN=false
PIPELINE_TIMEOUT=600
DPNS_DATABASE_PATH=data/dpns.db
LLM_SCORING_MODEL=anthropic/claude-haiku-4.5
LLM_DIGEST_MODEL=anthropic/claude-sonnet-4-6
LLM_MODEL_FALLBACK=anthropic/claude-haiku-4.5
